# ==============================================
# 本番環境用の環境変数テンプレート
# このファイルを .env.production にコピーして使用してください:
#   cp .env.production.example .env.production
# VPS上でDocker Composeを使用する場合の設定
# ==============================================

# Node.js version
NODE_VERSION=22

# PostgreSQL version
POSTGRES_VERSION=17-bookworm

# ==============================================
# Database configuration (本番環境用)
# compose.production.yamlのpostgresdbサービスに接続
# ==============================================
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432
POSTGRES_USER=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=nextjsapp-production

# DATABASE_URL (Prisma が自動的に使用)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================
# Node.js configuration (本番環境用)
# ==============================================
NODE_ENV=production

# ==============================================
# NextAuth configuration (本番環境用)
# ==============================================
# NEXTAUTH_URL (必須：本番環境のURL)
NEXTAUTH_URL=https://yourdomain.com

# NEXTAUTH_SECRET (必須：本番環境用シークレットキー)
# 未設定のまま起動するとエラーになります
# 生成方法: make prod-secret
NEXTAUTH_SECRET=

# ==============================================
# Square configuration (本番環境用)
# https://developer.squareup.com/apps
# ==============================================
# SQUARE_ACCESS_TOKEN=your_square_access_token_here
# SQUARE_APPLICATION_ID=your_square_application_id_here
# SQUARE_LOCATION_ID=your_square_location_id_here
# SQUARE_ENVIRONMENT=production

# ==============================================
# CORS configuration
# ==============================================
# LP問い合わせフォームの送信元オリジン（未設定時は "*" で全オリジン許可）
# 本番では LP の正確なオリジンを指定してください
ALLOWED_ORIGIN=https://yourdomain.com
